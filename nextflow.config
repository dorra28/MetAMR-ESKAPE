manifest {
    name            = 'MetAMR-ESKAPE'
    description     = 'Genome-scale metabolic modeling of AMR in ESKAPE pathogens'
    author          = 'Dorra Rjaibi (Institut Pasteur de Tunis)'
    version         = '0.1.0'
    nextflowVersion = '>=23.04.0'
}

params {
    samplesheet   = null      // CSV: sample_id,species,reads_1,reads_2,assembly
    outdir        = 'results'
    media         = 'M9,LB'   // CarveMe gap-filling media
    gram          = 'auto'    // gramneg / grampos / auto (guessed per species)
    skip_assembly = false     // set true if samplesheet already provides assemblies
    bakta_db      = '/opt/bakta_db'
}

profiles {
    standard {
        process.executor = 'local'
    }

    docker {
        docker.enabled   = true
        process.container = 'metamr-eskape:latest'
    }

    tesla_server {
        process.executor  = 'local'
        docker.enabled    = true
        process.container = 'metamr-eskape:latest'
        process.cpus      = 16
        process.memory    = '64 GB'
    }
}

process {
    withLabel: 'qc'          { cpus = 4;  memory = '8 GB'  }
    withLabel: 'assembly'    { cpus = 8;  memory = '16 GB' }
    withLabel: 'annotation'  { cpus = 4;  memory = '8 GB'  }
    withLabel: 'gem'         { cpus = 2;  memory = '8 GB'  }
}

report {
    enabled   = true
    file      = "${params.outdir}/pipeline_report.html"
}

timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_timeline.html"
}
